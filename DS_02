def kpi_card(label, value, sub=None, color=TEXT):
    children = [
        html.P(label, style={
            "margin":"0 0 4px", "fontSize":"11px", "color":MUTED,
            "fontFamily":FONT, "textTransform":"uppercase", "letterSpacing":"0.05em"
        }),
        html.P(value, style={
            "margin":"0", "fontSize":"22px", "fontWeight":"500",
            "color":color, "fontFamily":FONT
        }),
    ]
    if sub:
        children.append(html.P(sub, style={
            "margin":"2px 0 0", "fontSize":"11px",
            "color":MUTED, "fontFamily":FONT
        }))
    return html.Div(children, style={
        "background":"#F1EFE8", "borderRadius":"8px",
        "padding":"12px 16px", "flex":"1", "minWidth":"130px"
    })


