def base_layout(height=300, margin=None):
    m = margin or dict(l=10, r=10, t=30, b=10)
    return dict(
        height=height, margin=m,
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor ="rgba(0,0,0,0)",
        font=dict(family=FONT, color=TEXT, size=11),
        xaxis=dict(gridcolor=BORDER, linecolor=BORDER,
                   tickfont=dict(size=10, color=MUTED)),
        yaxis=dict(gridcolor=BORDER, linecolor="rgba(0,0,0,0)",
                   tickfont=dict(size=10, color=MUTED)),
        legend=dict(font=dict(size=10), bgcolor="rgba(0,0,0,0)"),
        hoverlabel=dict(bgcolor=CARD_BG, bordercolor=BORDER,
                        font=dict(family=FONT, size=12, color=TEXT))
    )


def chart_churn_donut(agg):
    kpis = agg["kpis"]
    fig = go.Figure(go.Pie(
        labels=["Retained", "Churned"],
        values=[kpis["retained"], kpis["churned"]],
        hole=0.65,
        marker=dict(colors=[TEAL, RED]),
        textinfo="label+percent",
        textfont=dict(size=11, family=FONT),
        hovertemplate="<b>%{label}</b><br>Customers: %{value:,}<br>Share: %{percent}<extra></extra>"
    ))
    layout = base_layout(height=240)
    layout.pop("xaxis", None)
    layout.pop("yaxis", None)
    layout["showlegend"] = False
    layout["margin"] = dict(l=10, r=10, t=10, b=10)
    fig.update_layout(**layout)
    return fig


def chart_retention_curve(agg):
    df_ret = agg["retention_df"]
    fig = go.Figure()
    fig.add_trace(go.Scatter(
        x=df_ret["Tenure"],
        y=df_ret["RetentionRate"],
        mode="lines",
        fill="tozeroy",
        line=dict(color=BLUE, width=2.5),
        fillcolor="rgba(24,95,165,0.08)",
        hovertemplate="Month %{x}<br>Retention: %{y:.1f}%<extra></extra>"
    ))
    # Mark the 12-month point
    val_12 = df_ret[df_ret["Tenure"]==12]["RetentionRate"].values
    if len(val_12):
        fig.add_vline(x=12, line_dash="dot", line_color=AMBER, line_width=1.5)
        fig.add_annotation(x=12, y=val_12[0], text=f" Month 12: {val_12[0]:.0f}%",
                           showarrow=False, font=dict(size=10, color=AMBER), xanchor="left")

    layout = base_layout(height=260)
    layout["xaxis"]["title"] = dict(text="Months Since Signup", font=dict(size=10, color=MUTED))
    layout["yaxis"]["title"] = dict(text="Retention %", font=dict(size=10, color=MUTED))
    layout["yaxis"]["range"] = [0, 105]
    fig.update_layout(**layout)
    return fig


