def load_and_clean(path):
    print("Loading data...")
    CSV = r"C:\Users\BOITUMELO\OneDrive\Desktop\DS-02\archive (6)\WA_Fn-UseC_-Telco-Customer-Churn.csv"
    df = pd.read_csv(CSV)
    print(f"   Raw rows     : {len(df):,}")

    # Fix TotalCharges -- stored as string with spaces
    df["TotalCharges"] = pd.to_numeric(df["TotalCharges"], errors="coerce")
    df["TotalCharges"].fillna(df["TotalCharges"].median(), inplace=True)

    # Binary churn flag
    df["ChurnFlag"] = (df["Churn"] == "Yes").astype(int)

    # Tenure bands for cohort grouping
    df["TenureBand"] = pd.cut(
        df["tenure"],
        bins=[0, 6, 12, 24, 36, 48, 60, 72],
        labels=["0-6m", "7-12m", "13-24m", "25-36m", "37-48m", "49-60m", "61-72m"]
    )

    # Monthly charge bands
    df["ChargeBand"] = pd.cut(
        df["MonthlyCharges"],
        bins=[0, 30, 50, 70, 90, 120],
        labels=["<$30", "$30-50", "$50-70", "$70-90", "$90+"]
    )

    print(f"   Clean rows   : {len(df):,}")
    print(f"   Churn rate   : {df['ChurnFlag'].mean()*100:.1f}%")
    return df



def build_aggregations(df):
    print("Building aggregations...")

    # -- Overall KPIs ----------------------------------------------------------
    total_customers  = len(df)
    churned          = df["ChurnFlag"].sum()
    churn_rate       = churned / total_customers
    retained         = total_customers - churned
    avg_tenure       = df["tenure"].mean()
    avg_monthly      = df["MonthlyCharges"].mean()
    avg_ltv          = df["TotalCharges"].mean()
    monthly_rev_risk = df[df["Churn"]=="Yes"]["MonthlyCharges"].sum()

    kpis = dict(
        total_customers=total_customers,
        churned=churned,
        churn_rate=churn_rate,
        retained=retained,
        avg_tenure=avg_tenure,
        avg_monthly=avg_monthly,
        avg_ltv=avg_ltv,
        monthly_rev_risk=monthly_rev_risk
    )

    # -- Churn by contract type ------------------------------------------------
    by_contract = (df.groupby("Contract")
                     .agg(Total=("ChurnFlag","count"),
                          Churned=("ChurnFlag","sum"))
                     .reset_index())
    by_contract["ChurnRate"] = by_contract["Churned"] / by_contract["Total"] * 100

    # -- Churn by tenure band --------------------------------------------------
    by_tenure = (df.groupby("TenureBand", observed=True)
                   .agg(Total=("ChurnFlag","count"),
                        Churned=("ChurnFlag","sum"))
                   .reset_index())
    by_tenure["ChurnRate"] = by_tenure["Churned"] / by_tenure["Total"] * 100

    # -- Churn by payment method -----------------------------------------------
    by_payment = (df.groupby("PaymentMethod")
                    .agg(Total=("ChurnFlag","count"),
                         Churned=("ChurnFlag","sum"))
                    .reset_index())
    by_payment["ChurnRate"] = by_payment["Churned"] / by_payment["Total"] * 100

    # -- Churn by internet service ---------------------------------------------
    by_internet = (df.groupby("InternetService")
                     .agg(Total=("ChurnFlag","count"),
                          Churned=("ChurnFlag","sum"))
                     .reset_index())
    by_internet["ChurnRate"] = by_internet["Churned"] / by_internet["Total"] * 100

    # -- Churn by monthly charge band ------------------------------------------
    by_charge = (df.groupby("ChargeBand", observed=True)
                   .agg(Total=("ChurnFlag","count"),
                        Churned=("ChurnFlag","sum"))
                   .reset_index())
    by_charge["ChurnRate"] = by_charge["Churned"] / by_charge["Total"] * 100

    retention = []
    for t in range(1, 73):
        cohort = df[df["tenure"] >= t]
        still_active = cohort[cohort["Churn"] == "No"]
        rate = len(still_active) / len(cohort) * 100 if len(cohort) else 0
        retention.append({"Tenure": t, "RetentionRate": rate, "Customers": len(cohort)})
    retention_df = pd.DataFrame(retention)

    services = ["PhoneService","MultipleLines","InternetService",
                "OnlineSecurity","OnlineBackup","DeviceProtection",
                "TechSupport","StreamingTV","StreamingMovies"]

    service_churn = []
    for svc in services:
        for val in df[svc].unique():
            sub = df[df[svc] == val]
            rate = sub["ChurnFlag"].mean() * 100
            service_churn.append({"Service": svc, "Value": val, "ChurnRate": rate, "Count": len(sub)})
    service_df = pd.DataFrame(service_churn)

    by_senior = (df.groupby("SeniorCitizen")
                   .agg(Total=("ChurnFlag","count"),
                        Churned=("ChurnFlag","sum"))
                   .reset_index())
    by_senior["Label"] = by_senior["SeniorCitizen"].map({0:"Non-Senior", 1:"Senior"})
    by_senior["ChurnRate"] = by_senior["Churned"] / by_senior["Total"] * 100

    by_paperless = (df.groupby("PaperlessBilling")
                      .agg(Total=("ChurnFlag","count"),
                           Churned=("ChurnFlag","sum"))
                      .reset_index())
    by_paperless["ChurnRate"] = by_paperless["Churned"] / by_paperless["Total"] * 100

    print("[OK] Aggregations done.")
    return dict(
        kpis=kpis,
        by_contract=by_contract,
        by_tenure=by_tenure,
        by_payment=by_payment,
        by_internet=by_internet,
        by_charge=by_charge,
        retention_df=retention_df,
        service_df=service_df,
        by_senior=by_senior,
        by_paperless=by_paperless
    )

def build_feature_importance(df):
    print("Running feature importance model...")

    features = [
        "tenure","MonthlyCharges","TotalCharges","SeniorCitizen",
        "Contract","PaymentMethod","InternetService",
        "OnlineSecurity","TechSupport","PaperlessBilling",
        "MultipleLines","StreamingTV","StreamingMovies"
    ]

    X = df[features].copy()

    # Encode categoricals
    le = LabelEncoder()
    for col in X.select_dtypes(include="object").columns:
        X[col] = le.fit_transform(X[col].astype(str))

    y = df["ChurnFlag"]

    rf = RandomForestClassifier(n_estimators=100, random_state=42, n_jobs=-1)
    rf.fit(X, y)

    importance_df = pd.DataFrame({
        "Feature":    features,
        "Importance": rf.feature_importances_
    }).sort_values("Importance", ascending=True)

    print("[OK] Model done.")
    return importance_df

