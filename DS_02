def chart_monthly_charges_dist(df):
    churned     = df[df["Churn"]=="Yes"]["MonthlyCharges"]
    not_churned = df[df["Churn"]=="No"]["MonthlyCharges"]
    fig = go.Figure()
    fig.add_trace(go.Histogram(
        x=not_churned, name="Retained",
        marker_color=TEAL, opacity=0.7,
        nbinsx=30, histnorm="percent",
        hovertemplate="$%{x}<br>%{y:.1f}% of retained<extra></extra>"
    ))
    fig.add_trace(go.Histogram(
        x=churned, name="Churned",
        marker_color=RED, opacity=0.7,
        nbinsx=30, histnorm="percent",
        hovertemplate="$%{x}<br>%{y:.1f}% of churned<extra></extra>"
    ))
    layout = base_layout(height=260)
    layout["barmode"]          = "overlay"
    layout["showlegend"]       = True
    layout["legend"]["x"]      = 0.7
    layout["legend"]["y"]      = 0.95
    layout["xaxis"]["tickprefix"] = "$"
    layout["xaxis"]["showgrid"]   = False
    fig.update_layout(**layout)
    return fig


