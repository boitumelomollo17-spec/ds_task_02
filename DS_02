    @app.callback(
        Output("contract-chart", "figure"),
        Output("tenure-chart",   "figure"),
        Input("contract-filter", "value")
    )
    def update_filtered(contract_val):
        filtered = df if contract_val == "All" else df[df["Contract"] == contract_val]

        # Re-compute churn by contract on filtered data
        bc = (filtered.groupby("Contract")
                      .agg(Total=("ChurnFlag","count"),
                           Churned=("ChurnFlag","sum"))
                      .reset_index())
        bc["ChurnRate"] = bc["Churned"] / bc["Total"] * 100
        colors = [RED if r > 30 else AMBER if r > 15 else GREEN for r in bc["ChurnRate"]]
        fig_contract = go.Figure(go.Bar(
            x=bc["ChurnRate"], y=bc["Contract"], orientation="h",
            marker_color=colors,
            text=[f"{r:.1f}%" for r in bc["ChurnRate"]], textposition="outside",
            hovertemplate="<b>%{y}</b><br>Churn: %{x:.1f}%<extra></extra>"
        ))
        layout = base_layout(height=220)
        layout["xaxis"]["ticksuffix"] = "%"
        layout["yaxis"]["showgrid"]   = False
        layout["margin"] = dict(l=10, r=60, t=10, b=10)
        fig_contract.update_layout(**layout)

        # Re-compute by tenure band
        bt = (filtered.groupby("TenureBand", observed=True)
                      .agg(Total=("ChurnFlag","count"),
                           Churned=("ChurnFlag","sum"))
                      .reset_index())
        bt["ChurnRate"] = bt["Churned"] / bt["Total"] * 100
        fig_tenure = go.Figure(go.Bar(
            x=[str(t) for t in bt["TenureBand"]],
            y=bt["ChurnRate"],
            marker=dict(color=bt["ChurnRate"],
                        colorscale=[[0,GREEN],[0.5,AMBER],[1,RED]],
                        showscale=False),
            text=[f"{r:.1f}%" for r in bt["ChurnRate"]], textposition="outside",
            hovertemplate="<b>%{x}</b><br>Churn: %{y:.1f}%<extra></extra>"
        ))
        layout2 = base_layout(height=240)
        layout2["yaxis"]["ticksuffix"] = "%"
        layout2["xaxis"]["showgrid"]   = False
        layout2["margin"] = dict(l=10, r=10, t=10, b=10)
        fig_tenure.update_layout(**layout2)

        return fig_contract, fig_tenure

    return app

